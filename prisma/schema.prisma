// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  profileId  Int     @id @default(autoincrement()) @map("profileId")
  first_name String  @default("default") @db.VarChar(255)
  last_name  String  @default("default") @db.VarChar(255)
  hidden     Int     @default(0) @db.SmallInt
  users      User[]

  @@map("profile")
}

model User {
  userId     Int        @id @default(autoincrement()) @map("userId")
  profileId  Int        @map("profileId")
  username   String     @default("default") @db.VarChar(255)
  password   String     @default("default") @db.VarChar(255)
  email      String     @default("default") @db.VarChar(255)
  blocked    Int        @default(0) @db.SmallInt
  token      String?    @default("default") @db.Text
  hidden     Int        @default(0) @db.SmallInt
  created_at DateTime?  @db.Timestamp(6)
  profile    Profile    @relation(fields: [profileId], references: [profileId])
  designs    Design[]
  works_done WorksDone[]
  palettes   Palettes[]
  tags       Tags[]

  @@map("users")
}

model Palettes {
  paletteId   Int         @id @default(autoincrement()) @map("paletteId")
  userId      Int?        @map("userId")
  name        String      @db.VarChar(255) // default is nor default must be null
  colors      String      @db.Text
  created_by  String      @default("SYSTEM") @db.VarChar(50) 
  createdDate DateTime    @map("created_date")  @default(now()) @db.Timestamp(6)
  hidden      Int         @default(0) @db.SmallInt
  user        User?       @relation(fields: [userId], references: [userId])
  works_done  WorksDone[]
  paletteTags PaletteTags[]

  @@map("palettes")
}

model Tags {
  tagId       Int         @id @default(autoincrement()) @map("tagId")
  userId      Int?        @map("userId")
  name        String      @default("default") @db.VarChar(255) // default is nor default must be null
  created_by  String      @default("SYSTEM") @db.VarChar(50) // Two options: SYSTEM or USER
  createdDate DateTime    @map("created_date")  @default(now()) @db.Timestamp(6)
  hidden      Int         @default(0) @db.SmallInt
  user        User?       @relation(fields: [userId], references: [userId])
  paletteTags PaletteTags[]

  @@map("tags")
}

model PaletteTags {
  paletteTagId  Int       @id @default(autoincrement()) @map("paletteTagId")
  tagId         Int       @map("tagId")
  paletteId     Int       @map("paletteId")
  createdDate   DateTime  @map("created_date")  @default(now()) @db.Timestamp(6)
  hidden        Int       @default(0) @db.SmallInt
  tag           Tags      @relation(fields: [tagId], references: [tagId])
  palette       Palettes  @relation(fields: [paletteId], references: [paletteId])

  @@unique([tagId, paletteId])
  @@map("palette_tags")
}

model Design {
  designId   Int         @id @default(autoincrement()) @map("designId")
  userId     Int         @map("userId")
  name       String?     @db.VarChar(255)
  pronts     String?     @db.Text
  img        String?     @db.VarChar(255)
  hidden     Int         @default(0) @db.SmallInt
  user       User        @relation(fields: [userId], references: [userId])
  works_done WorksDone[]

  @@map("designs")
}

model Image {
  imageId Int      @id @default(autoincrement()) @map("imageId")
  worldId Int      @map("worldId")
  path    String   @default("default") @db.VarChar(255)
  date    DateTime @db.Date
  hidden  Int      @default(0) @db.SmallInt
  work    WorksDone @relation(fields: [worldId], references: [worldId])

  @@map("images")
}

model WorksDone {
  worldId     Int          @id @default(autoincrement()) @map("worldId")
  designId    Int          @default(0) @map("designId")
  paletteId   Int          @default(0) @map("paletteId")
  userId      Int          @default(0) @map("userId")
  final_pront String?      @default("default") @db.Text
  hidden      Int          @default(0) @db.SmallInt
  design      Design       @relation(fields: [designId], references: [designId])
  palette     Palettes     @relation(fields: [paletteId], references: [paletteId])
  user        User         @relation(fields: [userId], references: [userId])
  images      Image[]

  @@map("works_done")
}
